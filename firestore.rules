rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // صلاحية الوصول إلى ملف المستخدم فقط
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // صلاحيات المقالات
    match /articles/{articleId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
      request.auth.uid == resource.data.authorId;
    }

    // صلاحيات الامتحانات (quizzes)
    match /quizzes/{quizId} {
    // Allow anyone to read a quiz, but only the creator can update or delete it.
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == resource.data.createdBy;

      // المجموعات (groups)
      match /groups/{groupId} {
        // Allow anyone to join a quiz (create a group) and read group data.
        allow read, create: if true;
        allow read, create: if true;
        // Allow updates/deletes by either the quiz owner or the group owner.
        allow update, delete: if request.auth != null &&
         (
           request.auth.uid == get(/databases/$(database)/documents/quizzes/$(quizId)).data.createdBy ||
            request.auth.uid == resource.data.ownerUid
          );
        // allow update, delete: if request.auth.uid == get(/databases/$(database)/documents/quizzes/$(quizId)).data.createdBy;
      }

      // حالة اللعبة (gameState)
      match /gameState/{gameStateId} {
        allow read: if true;
        allow write: if request.auth != null &&
          get(/databases/$(database)/documents/quizzes/$(quizId)).data.createdBy == request.auth.uid;
      }

      match /quizzes/{quizId}/gameState/state {
        // الكل يقدر يقرأ الحالة عشان الطلاب يعرفوا السؤال الحالي
        allow read: if true;
        // الـ Host فقط (منشئ الكويز) هو اللي يقدر يعدل الحالة
        allow write: if request.auth != null &&
                    get(/databases/$(database)/documents/quizzes/$(quizId)).data.createdBy == request.auth.uid;
      }
      // قواعد الفرق (Groups)
      match /quizzes/{quizId}/groups/{groupId} {
        // أي طالب يقدر ينضم (create) ويشوف الفرق
        allow create, read: if true;
        // الـ Host فقط هو اللي يقدر يمسح فريق أو ينظف الفرق القديمة
        allow delete: if request.auth != null &&
                    get(/databases/$(database)/documents/quizzes/$(quizId)).data.createdBy == request.auth.uid;
        // الطالب يقدر يحدث نشاطه فقط (Update lastActivity)
        allow update: if true;
      }
      // 1. الإجابات (Responses)
      match /quizzes/{quizId}/questions/{qIdx}/responses/{groupId} {
        // الطالب يقدر يبعت إجابته مرة واحدة (Create)
        // بشرط أن المسابقة نشطة ولسه وقت السؤال ما خلصش
        allow create: if request.resource.data.groupId == groupId
                      && get(/databases/$(database)/documents/quizzes/$(quizId)/gameState/state).data.showResults == false;

        // المضيف فقط هو اللي يقدر يشوف كل الإجابات
        allow read: if request.auth != null &&
                    get(/databases/$(database)/documents/quizzes/$(quizId)).data.createdBy == request.auth.uid;
      }

      // 2. تحديث النقاط (Scores)
      match /quizzes/{quizId}/groups/{groupId} {
        // الحماية هنا حرجة: الطالب لااااا يمكنه تعديل نقاطه بنفسه
        // التعديل فقط للمضيف
        allow update: if request.auth != null &&
                      get(/databases/$(database)/documents/quizzes/$(quizId)).data.createdBy == request.auth.uid;

        // الطلاب يقدروا يقرأوا النقاط عشان يشوفوا الـ Leaderboard
        allow read: if true;
      }

      // الردود (responses)
      match /responses/{responseId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if false;
      }
    }

    // سلة المحذوفات (trashedQuizzes)
    match /trashedQuizzes/{trashId} {
      // السماح بالقراءة والحذف فقط لو المستخدم هو صاحب المسابقة
      allow read, delete: if request.auth != null && request.auth.uid == resource.data.createdBy;

      // السماح بإنشاء ملف محذوف لو المستخدم مسجل دخول وهيسجل نفسه كـ صاحب للملف
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;

      // التعديل (Update) غالباً مش هنحتاجه في السلة فممكن نقفله
      allow update: if false;
    }

    match /conversations/{conversationId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // صلاحيات الآيات (verses)
    match /verses/{verseId} {
      allow read: if true;
      allow write: if request.auth != null; // Only authenticated users can modify verses
    }

    // صلاحيات جدولة الإشعارات (notificationSchedules)
    match /notificationSchedules/{scheduleId} {
      allow read: if true;
      allow write: if request.auth != null; // Only authenticated users can modify schedules
    }
  }
}
